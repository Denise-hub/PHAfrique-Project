# Copy to .env and fill in values.
# Database (SQLite). Path can be relative; the app resolves it to an absolute path at runtime
# so it works after renaming the project folder. Keep prisma/dev.db in the project.
# For CLI (prisma db push, migrate): file:./dev.db is relative to prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# NextAuth. NEXTAUTH_URL must match the URL in your browser (e.g. http://localhost:3000).
# NEXTAUTH_SECRET: use `openssl rand -base64 32`. If missing, admin login can throw.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-at-least-32-chars"

# Admin login (email/password). For SUPER_ADMIN (denmaombi@gmail.com), you can set ADMIN_PASSWORD
# to the plain password; the app will hash and store it on first login. Or use ADMIN_PASSWORD_HASH:
# node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""
ADMIN_PASSWORD_HASH=""

# Google OAuth — required for "Sign in with Google" on the admin login page.
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# (Web application, add Authorized redirect URI: https://your-domain/api/auth/callback/google)
# Admin users must exist in the DB (e.g. run db:seed or add via Profile); only those emails can sign in with Google.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP (for application status emails: accepted/rejected)
# Gmail: smtp.gmail.com, port 587, use App Password. Outlook: smtp.office365.com, port 587
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Optional: "From" address (defaults to SMTP_USER)
SMTP_FROM=""