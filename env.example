# Copy to .env and fill in values.
# Production (Vercel): set these in Vercel → Project → Settings → Environment Variables.
# Local: use Neon PostgreSQL for consistency, or the same Neon URL as production.

# Database: Neon PostgreSQL (pooled connection string). No SQLite in production.
# Get from Neon dashboard: Connection string → Pooled (Prisma-compatible).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth. In production set NEXTAUTH_URL to https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-at-least-32-chars"

# Admin login (email/password). For SUPER_ADMIN, set ADMIN_PASSWORD to the plain password.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""
ADMIN_PASSWORD_HASH=""

# Google OAuth — for "Sign in with Google" on admin login.
# Authorized redirect URI: https://your-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary — required for image uploads in production. Store only URLs in DB.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="phafrique"

# SMTP (optional, for application status emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
